# Gemini AI API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Outbound Email (SMTP) Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM='"Planet.X NOREPLY" <your_email@gmail.com>'

# Frontend Dynamic URL Redirects (verification, resets)
FRONTEND_URL=http://localhost:5173

# Database Settings (Local fallback or Production settings)
# For Aiven or online cloud MySQL, populate the environment variables below:
DATABASE_URL=mysql://user:pass@host:port/database_name?ssl-mode=REQUIRED
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASS=
DATABASE_NAME=planetx
DATABASE_SSLMODE=DISABLE
